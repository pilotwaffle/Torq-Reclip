# requirements.in — human-edited source for requirements.txt
#
# To regenerate requirements.txt with full transitive pins + hashes:
#
#   python3 -m venv .venv-pin
#   source .venv-pin/bin/activate
#   pip install pip-tools
#   pip-compile --generate-hashes --output-file=requirements.txt requirements.in
#   deactivate && rm -rf .venv-pin
#
# Until pip-tools is adopted, requirements.txt is hand-maintained to match
# the pins below. Dependabot will open PRs against requirements.txt directly.

flask==3.1.3
